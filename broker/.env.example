# Copy to .env (gitignored) for local dev, or set these as container env vars
# on Unraid. NEVER commit real values.

# GDTF Share service account (free signup at gdtf-share.com)
GDTF_SHARE_USER=vibe-broker@rehmlights
GDTF_SHARE_PASS=

# GitHub fine-grained PAT scoped to the rehmlights-profiles repo
# (Contents: read/write). Used only to push approved profiles.
GITHUB_TOKEN=
GITHUB_REPO=shanerehm1234/rehmlights-profiles

# Owner password for the /admin approve/reject page.
ADMIN_TOKEN=change-me

# Set to 0 to cook + stage but NOT push (dry run while testing).
PUBLISH_ENABLED=1
